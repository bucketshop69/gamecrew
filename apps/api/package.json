{
  "name": "@gamecrew/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "ingestion:smoke": "tsx src/match-ingestion-smoke.ts",
    "commentary:smoke": "tsx src/match-commentary-smoke.ts",
    "commentary:calibrate": "tsx src/match-commentary-calibration.ts",
    "commentary:materialize": "tsx src/materialize-match-pulse.ts",
    "match-pulse:live-test": "tsx src/live-match-pulse-test.ts",
    "match-pulse:replay": "tsx src/replay-match-pulse.ts",
    "start": "tsx src/server.ts",
    "test": "tsx --test 'tests/*.test.mjs'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gamecrew/core": "workspace:*",
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4"
  }
}
